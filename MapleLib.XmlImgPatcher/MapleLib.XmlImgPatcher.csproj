<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>MapleLib.XmlImgPatcher</RootNamespace>
    <AssemblyName>xml-img-patcher</AssemblyName>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>

    <!-- Defaults for `dotnet publish`: produce one self-contained .exe with no extra files. -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <DebugType>embedded</DebugType>
    <!-- AOT off: MapleLib uses Newtonsoft.Json reflection that AOT can't statically analyze. -->
    <PublishAot>false</PublishAot>

    <UseWindowsForms>true</UseWindowsForms>
    <UseWPF>true</UseWPF>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\MapleLib\MapleLib.csproj" />
  </ItemGroup>
</Project>

